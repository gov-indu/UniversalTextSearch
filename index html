const SR = {
  _cancelled: false,

  start() {
    if (!S.files.length) { UI.toast('Upload files first', 'warn'); return; }
    if (S.files.some(f=>f.loading)) { UI.toast('Files still scanning, please wait…', 'warn'); return; }

    const activeConds = S.query.groups.flatMap(g=>g.conditions)
      .filter(c => !['is_empty','is_not_empty'].includes(c.operator) && !c.value.trim());
    if (activeConds.length) { UI.toast('Fill in all condition values', 'warn'); return; }

    const filesToSearch = S.files
      .filter(f => !f.error && S.typeFilter.has(f.fileType))
      .filter(f => (f.sections||[]).some(s => s.enabled));

    if (!filesToSearch.length) { UI.toast('No sections selected — check Section Filter panel', 'warn'); return; }

    // Collapse sidebar panels for full results view
    UI.collapseAllPanels();
    RR.clear();
    S.matchCount = 0;
    this._cancelled = false;

    const query = {
      rootLogic: S.query.rootLogic,
      groups: S.query.groups.map(g=>({ logic:g.logic, conditions:g.conditions.map(c=>({...c})) }))
    };
    const compiledQuery = MatchEngine.compileQuery(query);
    const opts = {
      useHeader: $('uts-opt-first-row-header').checked,
      trimCells: $('uts-opt-trim-cells').checked,
    };

    UI.setSearching(true);
    UI.setProgress(0, 'Starting…');
    $('uts-main-title').textContent = 'Searching…';
    $('uts-main-sub').textContent = `0 of ${filesToSearch.length} file${filesToSearch.length!==1?'s':''} searched`;

    let fileIdx = 0, totalRows = 0, matchCount = 0;

    const processNextFile = async () => {
      if (this._cancelled || fileIdx >= filesToSearch.length) {
        this._finish(matchCount, totalRows, this._cancelled);
        return;
      }

      const fileEntry = filesToSearch[fileIdx++];
      const cfg = FILE_TYPE_CONFIG[fileEntry.fileType];
      const filePct = ((fileIdx - 1) / filesToSearch.length) * 100;

      UI.setProgress(filePct, `Parsing ${fileEntry.name}… (${fileIdx} of ${filesToSearch.length})`);
      $('uts-main-sub').textContent = `File ${fileIdx} of ${filesToSearch.length}: ${fileEntry.name}`;

      // ── Full parse (rows are created here, held briefly, then discarded) ──
      let sheets;
      try {
        sheets = await PARSERS[cfg.parse](fileEntry._file, opts);
      } catch(err) {
        console.warn(`Parse error for ${fileEntry.name}:`, err);
        if (!S.errors.some(e => e.name === fileEntry.name))
          S.errors.push({ name: fileEntry.name, reason: `Search-time parse failed: ${err.message}` });
        FM._renderErrorPanel();
        setTimeout(processNextFile, 0);
        return;
      }

      // Enabled section names for this file
      const enabledSections = new Set(
        (fileEntry.sections||[]).filter(s => s.enabled).map(s => s.name)
      );

      // ── Time-sliced search through this file's sheets ──
      let si = 0, ri = 0, batch = [];

      const flush = () => {
        if (batch.length) { RR.addBatch(batch.slice()); S.matchCount += batch.length; batch = []; }
      };

      const searchChunk = () => {
        if (this._cancelled) { flush(); this._finish(matchCount, totalRows, true); return; }

        const deadline = performance.now() + 14; // ~14ms per chunk → smooth 60fps
        while (performance.now() < deadline) {
          // Advance past sheets that don't exist or aren't enabled
          while (si < sheets.length && !enabledSections.has(sheets[si].name)) si++;
          if (si >= sheets.length) {
            // This file is done — discard rows and move on
            flush();
            sheets = null;
            const donePct = (fileIdx / filesToSearch.length) * 100;
            UI.setProgress(donePct, `${fmtNum(totalRows)} scanned · ${fmtNum(matchCount)} matches`);
            setTimeout(processNextFile, 0);
            return;
          }

          const sheet = sheets[si];
          if (ri >= sheet.rows.length) { si++; ri = 0; continue; }

          totalRows++;
          const { matched, cols } = MatchEngine.evalQuery(sheet.rows[ri], sheet.headers, compiledQuery);
          if (matched) {
            matchCount++;
            batch.push({
              fileId: fileEntry.id, fileName: fileEntry.name, fileType: fileEntry.fileType,
              sheetName: sheet.name, rowNum: ri + 1,
              rowData: sheet.rows[ri], headers: sheet.headers, matchedCols: cols
            });
            if (batch.length >= 80) flush();
          }
          ri++;
        }

        // Yield to browser between chunks
        UI.setProgress(
          filePct + ((si / Math.max(1, sheets.length)) * (100 / filesToSearch.length)),
          `${fileEntry.name} — ${fmtNum(totalRows)} scanned · ${fmtNum(matchCount)} matches`
        );
        setTimeout(searchChunk, 0);
      };

      searchChunk();
    };

    processNextFile();
  },

  cancel() { this._cancelled = true; },

  _finish(matchCount, totalRows, cancelled) {
    UI.setSearching(false);
    UI.setProgress(100, 'Done');
    setTimeout(() => UI.showProgress(false), 800);
    $('uts-btn-clear-results').disabled = matchCount === 0;

    if (cancelled) {
      UI.toast(`Cancelled · ${fmtNum(matchCount)} matches shown`, 'warn');
      $('uts-main-title').textContent = 'Search cancelled';
      $('uts-main-sub').textContent = `${fmtNum(matchCount)} matches found before cancel`;
    } else if (matchCount === 0) {
      RR.showNoResults();
      $('uts-main-title').textContent = 'No matches found';
      $('uts-main-sub').textContent = 'Try different keywords, fewer conditions, or switch AND → OR';
    } else {
      UI.toast(`${fmtNum(matchCount)} matches found`, 'ok');
      $('uts-main-title').textContent = `${fmtNum(matchCount)} matches`;
      $('uts-main-sub').textContent = `across ${fmtNum(totalRows)} entries scanned`;
    }

    RR.renderToolbar(matchCount);
  },
};

/* ══════════════════════════════════════════════════════════════
   RESULTS RENDERER
═══════════════════════════════════════════════════════════════ */
const RR = {
  _groups: {},
  _PAGE: 100,

  clear() {
    this._groups = {};
    const cont = $('uts-results-container');
    cont.innerHTML = `
      <div class="state-card" id="uts-empty-state">
        <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <circle cx="11" cy="15" r="3"/>
          <line x1="16" y1="20" x2="13.5" y2="17.5"/>
        </svg>
        <h3>No results yet</h3>
        <p>Upload files, build your query, then click <strong>Search</strong>.</p>
        <span class="hint">All processing happens locally — your data never leaves your device.</span>
      </div>`;
    $('uts-results-toolbar').style.display = 'none';
    $('uts-results-toolbar').innerHTML = '';
    $('uts-btn-clear-results').disabled = true;
    $('uts-main-title').textContent = 'Ready to Search';
    $('uts-main-sub').textContent = 'Upload documents, build your query, then click Search';
  },

  showNoResults() {
    $('uts-results-container').innerHTML = `
      <div class="state-card">
        <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        <h3>No matches found</h3>
        <p>None of the loaded content matched your conditions.</p>
        <span class="hint">Try: fewer conditions · switch AND to OR · use "contains" instead of "equals"</span>
      </div>`;
  },

  // Determine if a group uses snippet (card) view vs table view
  _isSnippet(fileType) {
    return fileType && fileType !== 'excel';
  },

  // Extract search terms from the current query for highlighting
  _getHighlightTerms() {
    const terms = [];
    const textOps = new Set(['contains','not_contains','equals','not_equals','starts_with','ends_with','fuzzy']);
    S.query.groups.forEach(g => g.conditions.forEach(c => {
      if (textOps.has(c.operator) && !c.negate && c.value.trim()) {
        terms.push({ term:c.value.trim(), cs:c.caseSensitive });
      }
    }));
    return terms;
  },

  // Apply highlights to escaped text
  _applyHighlight(escapedText, terms) {
    if (!terms.length) return escapedText;
    let result = escapedText;
    for (const { term, cs } of terms) {
      const escapedTerm = esc(term).replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
      const flags = cs ? 'g' : 'gi';
      try {
        result = result.replace(
          new RegExp(escapedTerm, flags),
          m => `<mark class="snip-hl">${m}</mark>`
        );
      } catch(e){}
    }
    return result;
  },

  addBatch(batch) {
    const cont = $('uts-results-container');
    const es = $('uts-empty-state');
    if (es) es.remove();

    const terms = this._getHighlightTerms();

    batch.forEach(row => {
      const key = `${row.fileId}::${row.sheetName}`;

      if (!this._groups[key]) {
        const gEl = document.createElement('div');
        gEl.className = 'result-group';
        cont.appendChild(gEl);
        const useSnippet = this._isSnippet(row.fileType);
        this._groups[key] = {
          el: gEl, allRows:[], shown:0,
          headers:row.headers, fileName:row.fileName, sheetName:row.sheetName,
          fileId:row.fileId, fileType:row.fileType, useSnippet
        };
        this._renderGroupHeader(key);
      }

      const g = this._groups[key];
      g.allRows.push(row);

      if (g.shown < this._PAGE) {
        if (g.useSnippet) {
          const list = g.el.querySelector('.snip-list');
          if (list) { list.insertAdjacentHTML('beforeend', this._snippetCardHTML(row, terms)); g.shown++; }
        } else {
          const tbody = g.el.querySelector('tbody');
          if (tbody) { tbody.insertAdjacentHTML('beforeend', this._tableRowHTML(row)); g.shown++; }
        }
        this._updateGroupFooter(key);
      }
    });
  },

  _renderGroupHeader(key) {
    const g = this._groups[key];
    const cfg = FILE_TYPE_CONFIG[g.fileType] || FILE_TYPE_CONFIG.unknown;
    const badge = `<span class="type-badge" style="background:${cfg.bg};color:${cfg.color}">${cfg.label}</span>`;

    const innerBody = g.useSnippet
      ? `<div class="snip-list" id="uts-snip-${CSS.escape(key)}"></div>`
      : `<div class="rg-tbl-wrap">
          <table class="rg-tbl">
            <thead><tr>
              <th class="row-num-h">#</th>
              ${g.headers.map(h=>`<th>${esc(h)}</th>`).join('')}
            </tr></thead>
            <tbody></tbody>
          </table>
        </div>`;

    g.el.innerHTML = `
      <div class="rg-hdr open" onclick="RR.toggleGroup('${key}')">
        <span class="rg-toggle">▶</span>
        <span class="rg-file">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          ${badge}
          ${esc(g.fileName)}
        </span>
        <span class="rg-sheet">${esc(g.sheetName)}</span>
        <span class="rg-count" id="uts-rgc-${CSS.escape(key)}">0 matches</span>
      </div>
      <div class="rg-body">
        ${innerBody}
        <div class="rg-footer" id="uts-rgf-${CSS.escape(key)}">
          <span class="rg-shown"></span>
          <button class="btn-load-more" onclick="RR.loadMore('${key}')">Load more</button>
        </div>
      </div>`;
  },

  _snippetCardHTML(row, terms) {
    const rawText = String(row.rowData[0] ?? '');
    const highlighted = this._applyHighlight(esc(rawText), terms);
    const lineLabel = row.rowNum !== undefined ? `#${row.rowNum}` : '';
    return `
      <div class="snip-card">
        <div class="snip-meta">
          <span class="snip-section-lbl">${esc(row.sheetName)}</span>
          ${lineLabel ? `<span class="snip-line-num">${lineLabel}</span>` : ''}
        </div>
        <div class="snip-text">${highlighted}</div>
      </div>`;
  },

  _tableRowHTML(row) {
    const mcSet = new Set(row.matchedCols);
    return `<tr>
      <td class="row-num">${row.rowNum}</td>
      ${row.rowData.map((cell,i) => {
        const v = esc(String(cell??''));
        return `<td title="${v}">${mcSet.has(i)?`<span class="cell-match">${v}</span>`:v}</td>`;
      }).join('')}
    </tr>`;
  },

  _updateGroupFooter(key) {
    const g = this._groups[key];
    const countEl = document.getElementById('uts-rgc-' + CSS.escape(key));
    if (countEl) countEl.textContent = `${fmtNum(g.allRows.length)} match${g.allRows.length!==1?'es':''}`;
    const footer = document.getElementById('uts-rgf-' + CSS.escape(key));
    if (!footer) return;
    const remaining = g.allRows.length - g.shown;
    footer.querySelector('.rg-shown').textContent =
      `Showing ${fmtNum(g.shown)} of ${fmtNum(g.allRows.length)}`;
    const moreBtn = footer.querySelector('.btn-load-more');
    if (moreBtn) moreBtn.style.display = remaining > 0 ? '' : 'none';
  },

  loadMore(key) {
    const g = this._groups[key];
    if (!g) return;
    const start = g.shown;
    const end   = Math.min(start + this._PAGE, g.allRows.length);
    const terms = this._getHighlightTerms();

    if (g.useSnippet) {
      const list = g.el.querySelector('.snip-list');
      if (list) {
        for (let i=start; i<end; i++) {
          list.insertAdjacentHTML('beforeend', this._snippetCardHTML(g.allRows[i], terms));
        }
      }
    } else {
      const tbody = g.el.querySelector('tbody');
      if (tbody) {
        for (let i=start; i<end; i++) {
          tbody.insertAdjacentHTML('beforeend', this._tableRowHTML(g.allRows[i]));
        }
      }
    }
    g.shown = end;
    this._updateGroupFooter(key);
  },

  toggleGroup(key) {
    const g = this._groups[key];
    if (!g) return;
    const hdr  = g.el.querySelector('.rg-hdr');
    const body = g.el.querySelector('.rg-body');
    hdr.classList.toggle('open');
    body.style.display = hdr.classList.contains('open') ? 'block' : 'none';
  },

  renderToolbar(matchCount) {
    const el = $('uts-results-toolbar');
    if (!matchCount) { el.style.display='none'; return; }
    const groupCount = Object.keys(this._groups).length;
    el.style.display = 'block';
    el.innerHTML = `
      <div class="rtb">
        <span class="rtb-count">${fmtNum(matchCount)} matches</span>
        <span class="rtb-sub">in ${groupCount} group${groupCount!==1?'s':''}</span>
        <div class="rtb-btns">
          <button class="rtb-btn" onclick="RR.collapseAll(false)">Expand All</button>
          <button class="rtb-btn" onclick="RR.collapseAll(true)">Collapse All</button>
          <button class="rtb-btn primary" onclick="EX.toXLSX()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export .xlsx
          </button>
          <button class="rtb-btn" onclick="EX.toCSV()">Export .csv</button>
        </div>
      </div>`;
  },

  collapseAll(collapse) {
    Object.keys(this._groups).forEach(key => {
      const g = this._groups[key];
      if (!g) return;
      const hdr  = g.el.querySelector('.rg-hdr');
      const body = g.el.querySelector('.rg-body');
      if (collapse) { hdr.classList.remove('open'); body.style.display = 'none'; }
      else          { hdr.classList.add('open');    body.style.display = 'block'; }
    });
  },
};

/* ══════════════════════════════════════════════════════════════
   EXPORTER
═══════════════════════════════════════════════════════════════ */
const EX = {
  _collectRows() {
    return Object.values(RR._groups).flatMap(g => g.allRows);
  },

  // Builds one unified table for ALL matches regardless of source file/type.
  // Columns are a union of every distinct header seen across results (in
  // first-seen order), so Excel column data and PDF/DOCX/PPTX/text "Text"
  // rows can all sit in the same sheet — rows just leave unrelated columns blank.
  _buildCombined(rows) {
    const headerUnion = [];
    const headerIndex = {};
    rows.forEach(r => {
      r.headers.forEach(h => {
        if (!(h in headerIndex)) { headerIndex[h] = headerUnion.length; headerUnion.push(h); }
      });
    });
    const dataRows = rows.map(r => {
      const cfg = FILE_TYPE_CONFIG[r.fileType] || FILE_TYPE_CONFIG.unknown;
      const vals = new Array(headerUnion.length).fill('');
      r.headers.forEach((h,i) => { vals[headerIndex[h]] = r.rowData[i] ?? ''; });
      return [r.rowNum, r.fileName, cfg.label, r.sheetName, ...vals];
    });
    return { columns: ['#','File','Type','Section', ...headerUnion], dataRows };
  },

  toXLSX() {
    const rows = this._collectRows();
    if (!rows.length) { UI.toast('No results to export', 'warn'); return; }

    const wb = XLSX.utils.book_new();

    // Sheet 1: Metadata
    const meta = [
      ['Universal Text Search — Export'],
      ['Generated', new Date().toLocaleString()],
      ['Total Matches', rows.length],
      ['Files Searched', [...new Set(rows.map(r=>r.fileName))].join(', ')],
      [''],
      ['Query Summary'],
      ['Root Logic', S.query.rootLogic],
      ...S.query.groups.map((g,i) => [
        `Group ${i+1} (${g.logic})`,
        g.conditions.map(c =>
          `${c.negate?'NOT ':''}[${c.column==='*'?'Any':c.column}] ${c.operator} "${c.value}"${c.value2?' to "'+c.value2+'"':''}`
        ).join(' | ')
      ]),
    ];
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(meta), 'Search Info');

    // Sheet 2: ALL matches combined into a single sheet (not split by file/section)
    const { columns, dataRows } = this._buildCombined(rows);
    const ws = XLSX.utils.aoa_to_sheet([columns, ...dataRows]);
    XLSX.utils.book_append_sheet(wb, ws, 'All Results');

    XLSX.writeFile(wb, `search_results_${Date.now()}.xlsx`);
    UI.toast(`Exported ${rows.length} matches to Excel`, 'ok');
  },

  toCSV() {
    const rows = this._collectRows();
    if (!rows.length) { UI.toast('No results to export', 'warn'); return; }

    const { columns, dataRows } = this._buildCombined(rows);
    const csvRows = [
      columns.map(EX._csvCell).join(','),
      ...dataRows.map(r => r.map(EX._csvCell).join(','))
    ];
    const blob = new Blob(['\ufeff'+csvRows.join('\r\n')], {type:'text/csv;charset=utf-8'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `search_results_${Date.now()}.csv`;
    a.click();
    URL.revokeObjectURL(a.href);
    UI.toast(`Exported ${rows.length} matches to CSV`, 'ok');
  },

  _csvCell(v) {
    const s = String(v??'');
    return s.includes(',') || s.includes('"') || s.includes('\n')
      ? '"' + s.replace(/"/g,'""') + '"' : s;
  },
};

/* ══════════════════════════════════════════════════════════════
   BOOTSTRAP
═══════════════════════════════════════════════════════════════ */
window.addEventListener('DOMContentLoaded', () => {
  QB.init();

  // Set initial panel states
  document.querySelectorAll('.panel-hdr').forEach(h => {
    const isOpen = h.classList.contains('open');
    const body = h.nextElementSibling;
    if (body && body.classList.contains('panel-body')) {
      body.style.display = isOpen ? 'block' : 'none';
    }
  });

  UI.toast('Ready — upload any document to begin', '', 3200);
});

// Expose all modules for inline onclick handlers
Object.assign(window, { FM, QB, SR, RR, EX, UI });
