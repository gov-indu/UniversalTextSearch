═══════════════════════════════════════════════════════════════ */
const WORKER_SRC = `
'use strict';
let _cancelled = false;

function lev(s,t){
  const m=s.length,n=t.length;
  if(!m)return n;if(!n)return m;
  const d=[];
  for(let i=0;i<=m;i++){d[i]=[i];}
  for(let j=0;j<=n;j++){d[0][j]=j;}
  for(let j=1;j<=n;j++)for(let i=1;i<=m;i++)
    d[i][j]=s[i-1]===t[j-1]?d[i-1][j-1]:1+Math.min(d[i-1][j],d[i][j-1],d[i-1][j-1]);
  return d[m][n];
}

function fuzzy(cell,term,threshold){
  return cell.split(/\\s+/).some(w=>lev(w,term)<=threshold);
}

// Precompute everything that does NOT change per row (regex objects,
// lowercased terms, parsed numeric/date bounds) — this runs once per
// search instead of once per row, which is the dominant cost for
// regex/fuzzy/date/numeric conditions on large datasets.
function compileCondition(cond){
  const cs = cond.caseSensitive;
  const c = Object.assign({}, cond);
  c.lcValue  = cs ? (cond.value||'')  : (cond.value||'').toLowerCase();
  c.lcValue2 = cs ? (cond.value2||'') : (cond.value2||'').toLowerCase();
  if (cond.operator === 'regex') {
    try { c.compiledRegex = new RegExp(cond.value, cs ? '' : 'i'); }
    catch(e) { c.compiledRegex = null; }
  } else if (cond.operator === 'fuzzy') {
    c.fuzzyThreshold = Math.max(1, Math.floor((cond.value||'').length*.35));
  } else if (cond.operator.indexOf('num_') === 0) {
    c.numValue  = parseFloat(cond.value);
    c.numValue2 = parseFloat(cond.value2);
  } else if (cond.operator.indexOf('date_') === 0) {
    c.dateValue  = new Date(cond.value);
    c.dateValue2 = new Date(cond.value2);
  }
  return c;
}
function compileQuery(query){
  return {
    rootLogic: query.rootLogic,
    groups: query.groups.map(g => ({ logic:g.logic, conditions:g.conditions.map(compileCondition) }))
  };
}

function testRaw(raw,cond){
  const val=raw!==null&&raw!==undefined?String(raw):'';
  const cs=cond.caseSensitive;
  const cv=cs?val:val.toLowerCase();
  const sv=cond.lcValue;
  switch(cond.operator){
    case 'contains':     return cv.includes(sv);
    case 'not_contains': return !cv.includes(sv);
    case 'equals':       return cv===sv;
    case 'not_equals':   return cv!==sv;
    case 'starts_with':  return cv.startsWith(sv);
    case 'ends_with':    return cv.endsWith(sv);
    case 'is_empty':     return val.trim()==='';
    case 'is_not_empty': return val.trim()!=='';
    case 'fuzzy':        return fuzzy(cv,sv,cond.fuzzyThreshold);
    case 'regex':        return cond.compiledRegex ? cond.compiledRegex.test(val) : false;
    case 'num_eq':      {const n=parseFloat(val);return!isNaN(n)&&n===cond.numValue;}
    case 'num_gt':      {const n=parseFloat(val);return!isNaN(n)&&n>cond.numValue;}
    case 'num_gte':     {const n=parseFloat(val);return!isNaN(n)&&n>=cond.numValue;}
    case 'num_lt':      {const n=parseFloat(val);return!isNaN(n)&&n<cond.numValue;}
    case 'num_lte':     {const n=parseFloat(val);return!isNaN(n)&&n<=cond.numValue;}
    case 'num_between': {const n=parseFloat(val);return!isNaN(n)&&!isNaN(cond.numValue)&&!isNaN(cond.numValue2)&&n>=cond.numValue&&n<=cond.numValue2;}
    case 'date_before': {const d=new Date(val);return!isNaN(d)&&!isNaN(cond.dateValue)&&d<cond.dateValue;}
    case 'date_after':  {const d=new Date(val);return!isNaN(d)&&!isNaN(cond.dateValue)&&d>cond.dateValue;}
    case 'date_on':     {const d=new Date(val);return!isNaN(d)&&!isNaN(cond.dateValue)&&d.toDateString()===cond.dateValue.toDateString();}
    case 'date_between':{const d=new Date(val);return!isNaN(d)&&!isNaN(cond.dateValue)&&!isNaN(cond.dateValue2)&&d>=cond.dateValue&&d<=cond.dateValue2;}
    default: return false;
  }
}

// Note: testRaw() never reads cond.negate — negation is applied by the
// caller below — so evalCond no longer needs to allocate a throwaway
// {...cond, negate:false} object or an index array on every row.
function evalCond(rowData,headers,cond){
  if (cond.column === '*') {
    if (cond.negate) {
      let anyPos = false;
      for (let i=0; i<rowData.length; i++) { if (testRaw(rowData[i],cond)) { anyPos=true; break; } }
      if (anyPos) return { matched:false, cols:[] };
      const cols = []; for (let i=0; i<rowData.length; i++) cols.push(i);
      return { matched:true, cols };
    }
    const matchedCols = [];
    for (let i=0; i<rowData.length; i++) { if (testRaw(rowData[i],cond)) matchedCols.push(i); }
    return { matched:matchedCols.length>0, cols:matchedCols };
  }
  const i = headers.indexOf(cond.column);
  if (i<0) return { matched:false, cols:[] };
  const raw = testRaw(rowData[i],cond);
  const hit = cond.negate ? !raw : raw;
  return { matched:hit, cols: hit?[i]:[] };
}

function evalGroup(rowData,headers,group){
  const res=group.conditions.map(c=>evalCond(rowData,headers,c));
  const matched=group.logic==='AND'?res.every(r=>r.matched):res.some(r=>r.matched);
  return{matched,cols:[...new Set(res.filter(r=>r.matched).flatMap(r=>r.cols))]};
}

function evalQuery(rowData,headers,compiledQuery){
  const res=compiledQuery.groups.map(g=>evalGroup(rowData,headers,g));
  const matched=compiledQuery.rootLogic==='AND'?res.every(r=>r.matched):res.some(r=>r.matched);
  return{matched,cols:[...new Set(res.filter(r=>r.matched).flatMap(r=>r.cols))]};
}

self.onmessage=function(e){
  const{type,payload}=e.data;
  if(type==='cancel'){_cancelled=true;return;}
  if(type!=='search')return;
  _cancelled=false;
  const{files,query,maxResults}=payload;
  const compiledQuery = compileQuery(query);
  let totalRows=0,matchCount=0,batch=[];

  for(const file of files){
    if(_cancelled)break;
    for(const sheet of file.sheets){
      if(_cancelled)break;
      const{name,headers,rows}=sheet;
      for(let i=0;i<rows.length;i++){
        if(_cancelled)break;
        totalRows++;
        if(totalRows%2000===0)
          self.postMessage({type:'progress',done:totalRows,match:matchCount,file:file.name,sheet:name});
        const{matched,cols}=evalQuery(rows[i],headers,compiledQuery);
        if(matched){
          matchCount++;
          batch.push({fileId:file.id,fileName:file.name,fileType:file.fileType,
            sheetName:name,rowNum:i+1,rowData:rows[i],headers,matchedCols:cols});
          if(batch.length>=80){self.postMessage({type:'results',batch:batch.slice()});batch=[];}
          if(matchCount>=maxResults){
            if(batch.length)self.postMessage({type:'results',batch});
            self.postMessage({type:'done',matchCount,totalRows,truncated:true});
            return;
          }
        }
      }
      self.postMessage({type:'sheet_done',file:file.name,sheet:name,rows:rows.length});
    }
  }
  if(batch.length)self.postMessage({type:'results',batch});
  if(_cancelled)self.postMessage({type:'cancelled',matchCount,totalRows});
  else self.postMessage({type:'done',matchCount,totalRows,truncated:false});
};
`;

