<script>
'use strict';

/* ══════════════════════════════════════════════════════════════
   CONSTANTS & UTILITIES
═══════════════════════════════════════════════════════════════ */
const FILE_TYPE_CONFIG = {
  excel:   { label:'XLS', color:'#059669', bg:'#dcfce7', parse:'excel'     },
  pdf:     { label:'PDF', color:'#dc2626', bg:'#fee2e2', parse:'pdf'       },
  docx:    { label:'DOC', color:'#7c3aed', bg:'#ede9fe', parse:'docx'      },
  pptx:    { label:'PPT', color:'#d97706', bg:'#fef3c7', parse:'pptx'      },
  text:    { label:'TXT', color:'#2563eb', bg:'#dbeafe', parse:'plainText' },
  legacy:  { label:'N/A', color:'#94a3b8', bg:'#f1f5f9', parse:null        },
  unknown: { label:'???', color:'#94a3b8', bg:'#f1f5f9', parse:null        },
};

const EXT_TO_TYPE = {
  xlsx:'excel', xls:'excel', csv:'excel',
  pdf:'pdf',
  docx:'docx',
  pptx:'pptx',
  txt:'text', lst:'text', log:'text', json:'text', xml:'text',
  md:'text', html:'text', htm:'text',
  doc:'legacy', ppt:'legacy', rtf:'legacy', odt:'legacy',
};

const SUPPORTED_PARSE_TYPES = new Set(['excel','pdf','docx','pptx','text']);

function getFileType(filename) {
  const ext = filename.split('.').pop().toLowerCase();
  return EXT_TO_TYPE[ext] || 'unknown';
}

function typeBadgeHTML(fileType) {
  const cfg = FILE_TYPE_CONFIG[fileType] || FILE_TYPE_CONFIG.unknown;
  return `<span class="type-badge" style="background:${cfg.bg};color:${cfg.color}">${cfg.label}</span>`;
}

let _uidCounter = 0;
const uid = () => 'id' + (++_uidCounter);
const esc = s => String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const fmtSize = b => b<1024?b+'B':b<1048576?(b/1024).toFixed(1)+'KB':(b/1048576).toFixed(1)+'MB';
const fmtNum  = n => n.toLocaleString();
const $  = id => document.getElementById(id);
const $$ = sel => document.querySelectorAll(sel);

/* ══════════════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════════════ */
const S = {
  mode: 'multi',
  files:    [],   // {id,name,size,fileType,sheets:[{name,headers,rows,enabled}],error,parseWarning,loading,_file}
  errors:   [],   // {name, reason} — legacy/unsupported files
  allCols:  [],
  typeFilter: new Set(Object.keys(FILE_TYPE_CONFIG)),
  query: { rootLogic:'AND', groups:[] },
  results: {},
  worker: null,
  searching: false,
  totalRows: 0,
  matchCount: 0,
};

/* ══════════════════════════════════════════════════════════════
   UI HELPERS
═══════════════════════════════════════════════════════════════ */
const UI = {
  togglePanel(hdr) {
    hdr.classList.toggle('open');
    const body = hdr.nextElementSibling;
    if (body && body.classList.contains('panel-body')) {
      body.style.display = hdr.classList.contains('open') ? 'block' : 'none';
    }
  },

  collapseAllPanels() {
    $$('.panel-hdr.open').forEach(hdr => {
      hdr.classList.remove('open');
      const body = hdr.nextElementSibling;
      if (body && body.classList.contains('panel-body')) body.style.display = 'none';
    });
  },

  _toastT: null,
  toast(msg, type='', dur=2600) {
    const el = $('uts-toast');
    el.textContent = msg;
    el.className = type ? `show ${type}` : 'show';
    clearTimeout(this._toastT);
    this._toastT = setTimeout(() => el.classList.remove('show'), dur);
  },

  setProgress(pct, label) {
    $('uts-prog-fill').style.width = pct + '%';
    $('uts-prog-pct').textContent = Math.round(pct) + '%';
    $('uts-prog-label').textContent = label;
  },

  showProgress(visible) {
    $('uts-progress-wrap').style.display = visible ? 'block' : 'none';
    if (!visible) this.setProgress(0, '');
  },

  setSearching(v) {
    S.searching = v;
    $('uts-btn-search').disabled = v;
    $('uts-btn-cancel').style.display = v ? 'flex' : 'none';
    this.showProgress(v);
  },
};

/* ══════════════════════════════════════════════════════════════
   PARSERS — one function per file type
   Each parser returns: [{name, headers, rows, enabled}]
═══════════════════════════════════════════════════════════════ */
const PARSERS = {

  // Helper: read file as ArrayBuffer
  _ab(file) {
    return new Promise((res, rej) => {
      const r = new FileReader();
      r.onload = e => res(e.target.result);
      r.onerror = () => rej(new Error('File read error'));
      r.readAsArrayBuffer(file);
    });
  },

  // Helper: read file as text
  _text(file) {
    return new Promise((res, rej) => {
      const r = new FileReader();
      r.onload = e => res(e.target.result);
      r.onerror = () => rej(new Error('File read error'));
      r.readAsText(file);
    });
  },

  // ══════════════════════════════════════════════════════════
  // SCAN variants — cheap, called at UPLOAD TIME.
  // Return [{name, headers, enabled}] with NO rows stored,
  // keeping RAM near-zero between upload and search time.
  // ══════════════════════════════════════════════════════════

  // Excel: sheetRows:2 so SheetJS only parses the header row + 1 data row.
  async excelScan(file, opts) {
    const ab = await PARSERS._ab(file);
    const wb = XLSX.read(new Uint8Array(ab), {
      type:'array', sheetRows: opts.useHeader ? 2 : 1, cellDates:false, cellNF:false
    });
    return wb.SheetNames.map(name => {
      const ws = wb.Sheets[name];
      const aoa = XLSX.utils.sheet_to_json(ws, {header:1, raw:true, defval:'', blankrows:false});
      const firstRow = aoa[0] || [];
      const headers = opts.useHeader
        ? firstRow.map((h, i) => { const s = opts.trimCells ? String(h??'').trim() : String(h??''); return s || `Col ${FM._colLbl(i)}`; })
        : firstRow.map((_, i) => `Col ${FM._colLbl(i)}`);
      return { name, headers: headers.length ? headers : ['Col A'], enabled: true };
    });
  },

  // PDF: just count pages — no text extraction yet.
  async pdfScan(file) {
    if (!window.pdfjsLib) throw new Error('PDF.js unavailable');
    if (!pdfjsLib.GlobalWorkerOptions.workerSrc)
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    const ab = await PARSERS._ab(file);
    const pdf = await pdfjsLib.getDocument({ data: new Uint8Array(ab) }).promise;
    return Array.from({ length: pdf.numPages }, (_, i) => ({ name: `Page ${i+1}`, headers: ['Text'], enabled: true }));
  },

  // DOCX: single stub — content extracted at search time.
  async docxScan() {
    return [{ name: 'Document', headers: ['Text'], enabled: true }];
  },

  // PPTX: count slides cheaply by listing ZIP entries.
  async pptxScan(file) {
    if (!window.JSZip) throw new Error('JSZip unavailable');
    const ab = await PARSERS._ab(file);
    const zip = await JSZip.loadAsync(ab);
    const count = Object.keys(zip.files).filter(f => /^ppt\/slides\/slide\d+\.xml$/.test(f)).length;
    return Array.from({ length: Math.max(1, count) }, (_, i) => ({ name: `Slide ${i+1}`, headers: ['Text'], enabled: true }));
  },

  // Text: single stub — no reading needed at upload time.
  async textScan() {
    return [{ name: 'Content', headers: ['Text'], enabled: true }];
  },

  // ══════════════════════════════════════════════════════════
  // FULL parsers — called at SEARCH TIME only, one file at a
  // time. Rows are discarded after each file is searched so
  // RAM stays bounded to one file at a time.
  // ══════════════════════════════════════════════════════════

  async plainText(file, opts) {
    const text = await PARSERS._text(file);
    const lines = text.split(/\r?\n/);
    const rows = lines.map(l => [opts.trimCells ? l.trim() : l]);
    return [{ name:'Content', headers:['Text'], rows }];
  },

  async excel(file, opts) {
    const ab = await PARSERS._ab(file);
    const wb = XLSX.read(new Uint8Array(ab), {type:'array', cellDates:true, cellNF:false});
    return wb.SheetNames.map(name => {
      const ws = wb.Sheets[name];
      const { headers, rows } = FM._wsToData(ws, opts.useHeader, opts.trimCells);
      return { name, headers, rows };
    });
  },

  async pdf(file, opts) {
    if (!window.pdfjsLib) throw new Error('PDF.js library unavailable. Check your internet connection and reload.');
    if (!pdfjsLib.GlobalWorkerOptions.workerSrc)
      pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    const ab = await PARSERS._ab(file);
    const pdf = await pdfjsLib.getDocument({ data: new Uint8Array(ab) }).promise;
    const sheets = [];
    for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
      const page = await pdf.getPage(pageNum);
      const content = await page.getTextContent();
      const lineMap = {};
      for (const item of content.items) {
        if (!item.str) continue;
        const y = Math.round(item.transform[5]);
        if (!lineMap[y]) lineMap[y] = [];
        lineMap[y].push(item.str);
      }
      const lines = Object.keys(lineMap).sort((a,b)=>Number(b)-Number(a))
        .map(y => lineMap[y].join('').trim()).filter(l => l.length > 0);
      if (lines.length > 0)
        sheets.push({ name:`Page ${pageNum}`, headers:['Text'], rows:lines.map(l=>[opts.trimCells?l.trim():l]) });
    }
    if (!sheets.length)
      sheets.push({ name:'Page 1', headers:['Text'], rows:[['[No extractable text — scanned/image-only PDF]']] });
    return sheets;
  },

  async docx(file, opts) {
    if (!window.JSZip) throw new Error('JSZip library unavailable. Check your internet connection and reload.');
    const ab = await PARSERS._ab(file);
    const zip = await JSZip.loadAsync(ab);
    const xmlFile = zip.file('word/document.xml');
    if (!xmlFile) throw new Error('Not a valid DOCX file (missing word/document.xml)');
    const xmlStr = await xmlFile.async('string');
    const doc = new DOMParser().parseFromString(xmlStr, 'text/xml');
    const paras = [...doc.querySelectorAll('p')].map(p =>
      [...p.querySelectorAll('t')].map(t => t.textContent).join('')
    ).filter(t => (opts.trimCells ? t.trim() : t).length > 0);
    if (!paras.length) throw new Error('No readable text found in document');
    return [{ name:'Document', headers:['Text'], rows:paras.map(p=>[opts.trimCells?p.trim():p]) }];
  },

  async pptx(file, opts) {
    if (!window.JSZip) throw new Error('JSZip library unavailable. Check your internet connection and reload.');
    const ab = await PARSERS._ab(file);
    const zip = await JSZip.loadAsync(ab);
    const slideKeys = Object.keys(zip.files)
      .filter(f => /^ppt\/slides\/slide\d+\.xml$/.test(f))
      .sort((a,b) => parseInt(a.match(/\d+/)[0]) - parseInt(b.match(/\d+/)[0]));
    if (!slideKeys.length) throw new Error('No slides found in PPTX file');
    const sheets = [];
    for (let i = 0; i < slideKeys.length; i++) {
      const xmlStr = await zip.file(slideKeys[i]).async('string');
      const doc = new DOMParser().parseFromString(xmlStr, 'text/xml');
      const paras = [...doc.querySelectorAll('p')].map(p =>
        [...p.querySelectorAll('t')].map(t => t.textContent).join('')
      ).filter(t => (opts.trimCells ? t.trim() : t).length > 0);
      if (paras.length > 0)
        sheets.push({ name:`Slide ${i+1}`, headers:['Text'], rows:paras.map(p=>[opts.trimCells?p.trim():p]) });
    }
    if (!sheets.length)
      sheets.push({ name:'Slide 1', headers:['Text'], rows:[['[No text content found in slides]']] });
    return sheets;
  },
};

/* ══════════════════════════════════════════════════════════════
   FILE MANAGER
═══════════════════════════════════════════════════════════════ */
const FM = {
  switchMode(mode, btn) {
    S.mode = mode;
    $$('.mtab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    $('uts-fi-multi').style.display = mode === 'multi' ? 'block' : 'none';
    $('uts-fi-dir').style.display   = mode === 'dir'   ? 'block' : 'none';
    if (mode === 'multi') $('uts-fi-dir').value = '';
    else $('uts-fi-multi').value = '';
  },

  onDragOver(e) { e.preventDefault(); $('uts-dropzone').classList.add('over'); },
  onDragLeave()  { $('uts-dropzone').classList.remove('over'); },
  onDrop(e) {
    e.preventDefault(); $('uts-dropzone').classList.remove('over');
    if (e.dataTransfer?.files?.length) this.addFiles(e.dataTransfer.files);
  },
  onSelect() {
    const inp = S.mode === 'multi' ? $('uts-fi-multi') : $('uts-fi-dir');
    if (inp.files?.length) this.addFiles(inp.files);
  },

  addFiles(rawList) {
    const all = Array.from(rawList);
    const supported = [], legacy = [], unknown = [];

    all.forEach(f => {
      const ft = getFileType(f.name);
      if (SUPPORTED_PARSE_TYPES.has(ft)) supported.push(f);
      else if (ft === 'legacy') legacy.push(f);
      else unknown.push(f);
    });

    // Track unsupported files in error panel
    legacy.forEach(f => {
      if (!S.errors.some(e => e.name === f.name)) {
        S.errors.push({ name:f.name, reason:'Legacy binary format (.doc/.ppt/.rtf/.odt) cannot be parsed in the browser. Convert to .docx / .pptx / .pdf first.' });
      }
    });
    unknown.forEach(f => {
      if (!S.errors.some(e => e.name === f.name)) {
        S.errors.push({ name:f.name, reason:'Unsupported file type.' });
      }
    });

    if (!supported.length) {
      const msg = (legacy.length + unknown.length) > 0
        ? `${legacy.length + unknown.length} unsupported file(s) — see error panel`
        : 'No supported files found in selection';
      UI.toast(msg, 'warn');
      this._renderErrorPanel();
      return;
    }

    if (legacy.length || unknown.length) {
      UI.toast(`${legacy.length + unknown.length} unsupported file(s) skipped — see error panel`, 'warn', 4000);
    }

    supported.forEach(f => this._addFile(f));
    this._renderErrorPanel();
  },

  _addFile(file) {
    // Skip duplicates
    if (S.files.some(f => f.name === file.name && f.size === file.size)) return;
    const id = uid();
    const fileType = getFileType(file.name);
    const entry = { id, name:file.name, size:file.size, fileType, sections:[], error:null, loading:true, _file:file };
    S.files.push(entry);
    this._renderFileList();
    this._parseFile(entry);
  },

  _parseFile(entry) {
    // Map file types to their cheap scan variant (headers + section names, NO rows)
    const scanMap = { excel:'excelScan', pdf:'pdfScan', docx:'docxScan', pptx:'pptxScan', text:'textScan' };
    const scanFn = scanMap[entry.fileType];
    if (!scanFn) {
      entry.loading = false;
      entry.error = 'Format not supported for in-browser parsing';
      if (!S.errors.some(e => e.name === entry.name))
        S.errors.push({ name: entry.name, reason: entry.error });
      this._afterParse();
      return;
    }

    const scan = async () => {
      try {
        const opts = {
          useHeader: $('uts-opt-first-row-header').checked,
          trimCells: $('uts-opt-trim-cells').checked,
        };
        entry.sections = await PARSERS[scanFn](entry._file, opts);
        entry.loading = false;
      } catch(err) {
        entry.loading = false;
        entry.error = err.message || 'Scan error';
        if (!S.errors.some(e => e.name === entry.name))
          S.errors.push({ name: entry.name, reason: `Failed to read: ${entry.error}` });
      }
      FM._afterParse();
    };
    scan();
  },

  // Shared Excel worksheet → {headers, rows} converter (also used by PARSERS.excel)
  // Uses SheetJS's native sheet_to_json(header:1) instead of manually walking
  // every cell address with encode_cell() — meaningfully faster on large sheets.
  _wsToData(ws, useHeader, trimCells) {
    const aoa = XLSX.utils.sheet_to_json(ws, { header:1, raw:true, defval:'', blankrows:true });
    if (!aoa.length) return { headers:[], rows:[] };

    const colCount = aoa.reduce((m,r) => Math.max(m, r.length), 0);
    const normCell = v => {
      if (v instanceof Date) v = v.toISOString().slice(0,10);
      if (trimCells && typeof v === 'string') v = v.trim();
      return v;
    };

    let headers, dataRows;
    if (useHeader) {
      const headerRow = aoa[0] || [];
      headers = [];
      for (let c=0; c<colCount; c++) {
        const raw = headerRow[c] !== undefined && headerRow[c] !== null ? String(headerRow[c]) : '';
        const h = trimCells ? raw.trim() : raw;
        headers.push(h || `Col ${FM._colLbl(c)}`);
      }
      dataRows = aoa.slice(1);
    } else {
      headers = [];
      for (let c=0; c<colCount; c++) headers.push(`Col ${FM._colLbl(c)}`);
      dataRows = aoa;
    }

    const rows = dataRows.map(r => {
      const row = new Array(colCount);
      for (let c=0; c<colCount; c++) row[c] = normCell(r[c] !== undefined ? r[c] : '');
      return row;
    });

    return { headers, rows };
  },

  _colLbl(i) {
    if (i<26) return String.fromCharCode(65+i);
    return String.fromCharCode(64+Math.floor(i/26)) + String.fromCharCode(65+(i%26));
  },

  _afterParse() {
    const allDone = S.files.every(f => !f.loading);
    this._renderFileList();
    this._updateColumnUnion();
    this._renderSheetList();
    this._renderTypeFilter();
    this._renderUploadSummary();
    this._renderErrorPanel();
    QB.refreshColumns();
    if (allDone) {
      const ok = S.files.filter(f=>!f.error).length;
      const fail = S.files.filter(f=> f.error).length;
      UI.toast(`${ok} file(s) ready to search${fail?' · '+fail+' failed':''}`, fail?'warn':'ok');
    }
  },

  reparse() {
    S.files.forEach(f => { f.loading = true; f.sections = []; this._parseFile(f); });
    this._renderFileList();
  },

  removeFile(id) {
    const idx = S.files.findIndex(f => f.id === id);
    if (idx < 0) return;
    S.files.splice(idx, 1);
    this._afterParse();
    if (!S.files.length) {
      $('uts-panel-sheets').style.display = 'none';
      $('uts-panel-type-filter').style.display = 'none';
    }
  },

  clearAllFiles() {
    if (!S.files.length) return;
    S.files = [];
    S.errors = [];
    this._afterParse();
    this._renderErrorPanel();
    $('uts-panel-sheets').style.display = 'none';
    $('uts-panel-type-filter').style.display = 'none';
    RR.clear();
    UI.toast('All files cleared');
  },

  _renderFileList() {
    const pb = $('uts-pb-files');
    pb.textContent = `${S.files.length} file${S.files.length!==1?'s':''}`;
    $('uts-upload-actions').style.display = S.files.length ? 'block' : 'none';
  },

  _renderSheetList() {
    const panel = $('uts-panel-sheets');
    const pb    = $('uts-pb-sheets');
    const list  = $('uts-sheet-list');
    const allSections = S.files.flatMap(f => (f.sections||[]).map(s => ({fid:f.id, fname:f.name, s})));
    if (!allSections.length) { panel.style.display='none'; return; }
    panel.style.display = '';
    pb.textContent = `${allSections.length} section${allSections.length!==1?'s':''}`;
    list.innerHTML = allSections.map(({fid,fname,s}) => `
      <label class="sheet-item">
        <input type="checkbox" ${s.enabled?'checked':''} onchange="FM.toggleSheet('${fid}','${esc(s.name)}',this.checked)">
        <span>${esc(s.name)}</span>
        <span class="sheet-fn">${esc(fname.length>20?fname.slice(0,18)+'…':fname)}</span>
      </label>`).join('');
  },

  _renderTypeFilter() {
    const panel = $('uts-panel-type-filter');
    const wrap  = $('uts-type-filter-wrap');
    const presentTypes = [...new Set(S.files.map(f => f.fileType))];
    if (!presentTypes.length) { panel.style.display='none'; return; }
    panel.style.display = '';
    wrap.innerHTML = presentTypes.map(type => {
      const cfg = FILE_TYPE_CONFIG[type] || FILE_TYPE_CONFIG.unknown;
      const on = S.typeFilter.has(type);
      return `
        <span class="tf-chip ${on?'':'off'}" data-type="${type}"
          style="background:${cfg.bg};color:${cfg.color};border-color:${cfg.color}"
          onclick="FM.toggleTypeFilter('${type}',this)">
          ${cfg.label}
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            ${on ? '<polyline points="20 6 9 17 4 12"/>' : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>'}
          </svg>
        </span>`;
    }).join('');
  },

  toggleTypeFilter(type, el) {
    if (S.typeFilter.has(type)) S.typeFilter.delete(type);
    else S.typeFilter.add(type);
    this._renderTypeFilter();
  },

  toggleSheet(fid, sname, val) {
    const f = S.files.find(f => f.id === fid);
    const s = f?.sections?.find(s => s.name === sname);
    if (s) s.enabled = val;
  },

  checkAllSheets(val) {
    S.files.forEach(f => (f.sections||[]).forEach(s => s.enabled = val));
    this._renderSheetList();
  },

  _updateColumnUnion() {
    const seen = new Set();
    S.files.forEach(f => (f.sections||[]).forEach(s => (s.headers||[]).forEach(h => { if(h) seen.add(h); })));
    S.allCols = [...seen].sort((a,b) => a.localeCompare(b));
  },

  _renderErrorPanel() {
    const el = $('uts-err-panel');
    if (!S.errors.length) { el.style.display='none'; el.innerHTML=''; return; }
    el.style.display = 'block';
    el.innerHTML = `
      <div class="err-card">
        <div class="err-card-title">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          ${S.errors.length} unsupported or failed file${S.errors.length!==1?'s':''}
        </div>
        ${S.errors.map(e => `
          <div class="err-item">
            <span class="err-name" title="${esc(e.name)}">${esc(e.name)}</span>
            <span class="err-reason">${esc(e.reason)}</span>
          </div>`).join('')}
      </div>`;
  },

  _renderUploadSummary() {
    const el = $('uts-upload-summary');
    if (!S.files.length) { el.style.display='none'; el.innerHTML=''; return; }
    el.style.display = 'block';

    const total    = S.files.length;
    const done     = S.files.filter(f => !f.loading);
    const doneCount= done.length;
    const errCount = done.filter(f => f.error).length;
    const okCount  = doneCount - errCount;
    const pct      = total ? (doneCount / total) * 100 : 0;
    const allDone  = doneCount === total;
    const totalSections = done.filter(f=>!f.error).reduce((a,f)=>a+(f.sections||[]).length,0);
    const totalSize     = S.files.reduce((a,f)=>a+f.size,0);

    const statusLabel = allDone
      ? `✓ ${okCount} of ${total} file${total!==1?'s':''} ready to search${errCount?` · ${errCount} failed`:''}`
      : `Scanning ${doneCount} of ${total} file${total!==1?'s':''}…`;

    el.innerHTML = `
      <div class="summ-card">
        <div class="summ-card-title">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          Upload Summary
        </div>
        <div class="summ-stats">
          <div class="stat-pill"><strong>${total}</strong> file${total!==1?'s':''}</div>
          <div class="stat-pill"><strong>${totalSections}</strong> section${totalSections!==1?'s':''}</div>
          <div class="stat-pill"><strong>${fmtSize(totalSize)}</strong> total</div>
          ${errCount ? `<div class="stat-pill fst-err"><strong>${errCount}</strong> failed</div>` : ''}
        </div>
        <div class="upload-prog-wrap">
          <div class="upload-prog-info">
            <span class="${allDone && !errCount ? 'fst-ok' : ''}">${statusLabel}</span>
            <span>${Math.round(pct)}%</span>
          </div>
          <div class="upload-prog-track"><div class="upload-prog-fill" style="width:${pct}%"></div></div>
        </div>
        <div style="margin-top:8px;padding:7px 10px;background:var(--blue-bg);border:1px solid var(--blue-br);border-radius:5px;font-size:.76rem;color:var(--blue)">
          ⚡ Rows are parsed on-demand at search time — one file at a time — to keep memory usage low.
        </div>
      </div>`;
  },
};

/* ══════════════════════════════════════════════════════════════
   QUERY BUILDER
═══════════════════════════════════════════════════════════════ */
const QB = {
  _OPERATORS: [
    {g:'Text', opts:[
      {v:'contains',     l:'contains'},
      {v:'not_contains', l:'does not contain'},
      {v:'equals',       l:'equals (exact)'},
      {v:'not_equals',   l:'not equals'},
      {v:'starts_with',  l:'starts with'},
      {v:'ends_with',    l:'ends with'},
      {v:'regex',        l:'matches regex'},
      {v:'fuzzy',        l:'fuzzy match (~)'},
    ]},
    {g:'Numeric', opts:[
      {v:'num_eq',      l:'= equal to'},
      {v:'num_gt',      l:'> greater than'},
      {v:'num_gte',     l:'>= at least'},
      {v:'num_lt',      l:'< less than'},
      {v:'num_lte',     l:'<= at most'},
      {v:'num_between', l:'between (numeric)'},
    ]},
    {g:'Date', opts:[
      {v:'date_before',  l:'date before'},
      {v:'date_after',   l:'date after'},
      {v:'date_on',      l:'date equals'},
      {v:'date_between', l:'date between'},
    ]},
    {g:'Existence', opts:[
      {v:'is_empty',     l:'is empty / blank'},
      {v:'is_not_empty', l:'is not empty'},
    ]},
  ],

  _opSet: null,
  _getOpSet() {
    if (!this._opSet) this._opSet = new Set(this._OPERATORS.flatMap(g=>g.opts.map(o=>o.v)));
    return this._opSet;
  },

  init() { this.addGroup(); this._renderPresets(); },

  newCond() {
    return {id:uid(), column:'*', operator:'contains', value:'', value2:'', negate:false, caseSensitive:false};
  },
  newGroup() { return {id:uid(), logic:'AND', conditions:[this.newCond()]}; },

  setRootLogic(v) {
    S.query.rootLogic = v;
    $('uts-rl-and').classList.toggle('active', v==='AND');
    $('uts-rl-or').classList.toggle('active', v==='OR');
    $$('.qb-connector').forEach(el => el.textContent = v);
  },

  addGroup() { S.query.groups.push(this.newGroup()); this._renderGroups(); },

  removeGroup(gid) {
    S.query.groups = S.query.groups.filter(g => g.id !== gid);
    if (!S.query.groups.length) this.addGroup();
    else this._renderGroups();
  },

  setGroupLogic(gid, v) {
    const g = S.query.groups.find(g=>g.id===gid);
    if (g) {
      g.logic = v;
      const el = document.querySelector(`.group-card[data-gid="${gid}"]`);
      if (el) el.querySelectorAll('.glbtn').forEach(b => b.classList.toggle('active', b.dataset.logic===v));
    }
  },

  addCondition(gid) {
    const g = S.query.groups.find(g=>g.id===gid);
    if (!g) return;
    const cond = this.newCond();
    g.conditions.push(cond);
    const list = document.querySelector(`.group-card[data-gid="${gid}"] .cond-list`);
    if (list) list.insertAdjacentHTML('beforeend', this._condHTML(gid, cond));
    setTimeout(() => {
      const inp = document.querySelector(`.cond-row[data-cid="${cond.id}"] .cond-val`);
      if (inp) inp.focus();
    }, 30);
  },

  removeCondition(gid, cid) {
    const g = S.query.groups.find(g=>g.id===gid);
    if (!g) return;
    g.conditions = g.conditions.filter(c=>c.id!==cid);
    if (!g.conditions.length) g.conditions.push(this.newCond());
    const list = document.querySelector(`.group-card[data-gid="${gid}"] .cond-list`);
    if (list) {
      const g2 = S.query.groups.find(g=>g.id===gid);
      list.innerHTML = g2.conditions.map(c=>this._condHTML(gid,c)).join('');
    }
  },

  updateCondVal(gid, cid, field, val) {
    const g = S.query.groups.find(g=>g.id===gid);
    const c = g?.conditions.find(c=>c.id===cid);
    if (c) c[field] = val;
  },

  updateCondOp(gid, cid, op) {
    const g = S.query.groups.find(g=>g.id===gid);
    const c = g?.conditions.find(c=>c.id===cid);
    if (!c) return;
    c.operator = op;
    const row = document.querySelector(`.cond-row[data-cid="${cid}"]`);
    if (row) row.querySelector('.cond-row-bot').innerHTML = this._condValHTML(gid, c);
  },

  toggleNegate(gid, cid) {
    const g = S.query.groups.find(g=>g.id===gid);
    const c = g?.conditions.find(c=>c.id===cid);
    if (!c) return;
    c.negate = !c.negate;
    const btn = document.querySelector(`.cond-row[data-cid="${cid}"] .cond-not`);
    if (btn) btn.classList.toggle('on', c.negate);
  },

  toggleCS(gid, cid, val) {
    const g = S.query.groups.find(g=>g.id===gid);
    const c = g?.conditions.find(c=>c.id===cid);
    if (c) c.caseSensitive = val;
  },

